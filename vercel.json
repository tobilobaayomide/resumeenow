{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/parse-resume.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/export-pdf.js": {
      "memory": 2048,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "^/api/(.*)$",
      "dest": "/api/$1"
    },
    {
      "src": "^/(?!api/|@|src/|node_modules/|.*\\..*).*$",
      "dest": "/index.html"
    }
  ]
}
